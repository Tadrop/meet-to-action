# ─────────────────────────────────────────────────────────────────
# Anthropic
# ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────
# Google OAuth2 — from Google Cloud Console (Desktop App credential)
# ─────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Path to the saved OAuth token (auto-created on first run)
GOOGLE_TOKEN_PATH=token.json
# Path to the client secrets JSON downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials.json

# ─────────────────────────────────────────────────────────────────
# Google Drive
# ─────────────────────────────────────────────────────────────────
# Name of the Drive folder where Google Meet saves recordings
DRIVE_TRANSCRIPTS_FOLDER=Meet Recordings

# ─────────────────────────────────────────────────────────────────
# Asana
# ─────────────────────────────────────────────────────────────────
# Personal Access Token from https://app.asana.com/0/developer-console
ASANA_ACCESS_TOKEN=...
# Workspace GID (visible in the URL: app.asana.com/0/{workspace_gid}/...)
ASANA_WORKSPACE_GID=...
# Default project GID where tasks will be created (optional)
ASANA_PROJECT_GID=...

# ─────────────────────────────────────────────────────────────────
# Notion
# ─────────────────────────────────────────────────────────────────
# Internal integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...
# Database ID from the Notion meeting database URL
NOTION_DATABASE_ID=...

# ─────────────────────────────────────────────────────────────────
# Pipeline behaviour
# ─────────────────────────────────────────────────────────────────
# Poll interval in minutes (default: 5)
POLL_INTERVAL_MINUTES=5
# Path to idempotency tracking file
PROCESSED_TRANSCRIPTS_PATH=processed_transcripts.json
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
